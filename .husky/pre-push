# Garde-fou — push direct sur master interdit (toute modification passe par une PR).

protected_branch="master"

# Lit stdin : "<local_ref> <local_sha> <remote_ref> <remote_sha>" par push
while read -r local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/heads/"$protected_branch")
      echo ""
      echo "BLOCKED: direct push to '$protected_branch' is forbidden."
      echo "  Use a Pull Request to merge into '$protected_branch'."
      echo ""
      exit 1
      ;;
  esac
done
